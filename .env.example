# Server
DEV_PORT=5000
PROD_PORT=8000
NODE_ENV=development

# Frontend URLs
DEV_FRONTEND_URL=http://localhost:3000
PROD_FRONTEND_URL=https://your-production-url.com

# MongoDB
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.example.mongodb.net/philz_db

# JWT
JWT_SECRET=generate-a-256-bit-hex-secret-here

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Resend (Email)
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=noreply@philzproperties.com

# Paystack
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key

# Discord (optional)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook
